# .env.example — Environment variable reference for the Deal Flow Engine
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Each variable is annotated with:
#   [REQUIRED - Slice N]  — must be set before that slice can run
#   [OPTIONAL]            — has a default; override to change behaviour
#
# Variables are grouped by the slice that first requires them.

# ---------------------------------------------------------------------------
# Slice 1 — Project Scaffold (required now)
# ---------------------------------------------------------------------------

# Postgres connection string.
# Format: postgresql://user:password@host:port/dbname
# Example: postgresql://dealflow:secret@localhost:5432/dealflow
DATABASE_URL=                                         # [REQUIRED - Slice 1]

# ---------------------------------------------------------------------------
# Slice 1 — Optional overrides (have working defaults)
# ---------------------------------------------------------------------------

# Directory where generated PDFs are written.
# Default: output
OUTPUT_DIR=output                                     # [OPTIONAL]

# LLM model identifier passed to the LLM API.
# Default: gpt-4o
LLM_MODEL=gpt-4o                                     # [OPTIONAL]

# ---------------------------------------------------------------------------
# Slice 2 — Database Schema and Migration Runner
# ---------------------------------------------------------------------------

# Postgres connection string for running tests.
# Must point to a test database, not production.
TEST_DATABASE_URL=postgresql://dealflow:1234@127.0.0.1:5432/dealflow  # [REQUIRED - Slice 2 tests]

# ---------------------------------------------------------------------------
# Slice 6 — Entity Extraction / LLM calls
# ---------------------------------------------------------------------------

# API key for the LLM provider (OpenAI or compatible).
LLM_API_KEY=                                          # [REQUIRED - Slice 6]

# Base URL for the LLM API. Leave blank to use the default OpenAI endpoint.
# Override to point to a local or alternative provider (e.g. LM Studio, Ollama proxy).
LLM_API_BASE_URL=https://api.openai.com/v1            # [REQUIRED - Slice 6]

# ---------------------------------------------------------------------------
# Slice 4 — Gmail Ingestion
# ---------------------------------------------------------------------------

# Path to the Gmail OAuth2 credentials JSON file (from Google Cloud Console).
# The file must be gitignored. See docs/decisions/gmail-oauth-approach.md.
GMAIL_CREDENTIALS_PATH=credentials/gmail_oauth.json  # [REQUIRED - Slice 4]

# ---------------------------------------------------------------------------
# Slice 5 — Google Calendar Ingestion
# ---------------------------------------------------------------------------

# Path to the Google Calendar OAuth2 credentials JSON file.
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials/calendar_oauth.json  # [REQUIRED - Slice 5]

# ---------------------------------------------------------------------------
# Slice 10 — Email Delivery (SMTP)
# ---------------------------------------------------------------------------

# The From address for the daily brief email.
EMAIL_FROM=dealflow@yourdomain.com                    # [REQUIRED - Slice 10]

# The To address that receives the daily brief.
EMAIL_TO=you@yourdomain.com                           # [REQUIRED - Slice 10]

# SMTP relay hostname.
SMTP_HOST=smtp.yourdomain.com                         # [REQUIRED - Slice 10]

# SMTP relay port. 587 (STARTTLS) is the recommended default.
SMTP_PORT=587                                         # [REQUIRED - Slice 10]

# SMTP authentication password.
SMTP_PASSWORD=                                        # [REQUIRED - Slice 10]
